{
  "name": "browserx",
  "version": "1.0.0",
  "description": "A cross-browser compatibility library for developers",
  "license": "MIT",
  "author": "OneilNvM <oneil324@outlook.com>",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/browserx.umd.cjs",
  "module": "./dist/browserx.js",
  "exports": {
    ".": {
      "import": "./dist/browserx.js",
      "require": "./dist/browserx.umd.cjs"
    }
  },
  "scripts": {
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vite build",
    "build:wasm": "wasm-pack build browserx-core --target web --out-dir ../pkg",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@mdn/browser-compat-data": "^7.3.6"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jsdom": "^28.1.0",
    "node": "^22.22.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}