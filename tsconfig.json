{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "rootDirs": [
            "src",
            "gen"
        ],
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*.js",
    ],
    "exclude": ["node_modules"]
}