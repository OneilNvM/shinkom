{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "rootDir": "src",
        "skipLibCheck": true,
    },
    "include": [
        "src/**/*.js"
    ],
    "exclude": ["node_modules"]
}