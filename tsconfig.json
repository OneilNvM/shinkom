{
    "compilerOptions": {
        "lib": [
            "ESNext",
            "DOM"
        ],
        "noEmit": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "target": "esnext",
        "module": "esnext",
        "strict": true,
        "noImplicitAny": true,
        "allowJs": true,
        "checkJs": true,
        "moduleResolution": "bundler"
    },
    "include": [
        "src/**/*.js",
        "tests/**/*.test.js",
        "types/**/*.d.ts",
        "pkg/**/*.d.ts"
    ],
    "exclude": ["node_modules"]
}